# Apex · environment template
#
# Copy this to `.env.local` for local dev (gitignored), or paste each row into
# Vercel's Project → Settings → Environment Variables before the first deploy.
# Every key below is FREE-TIER eligible · Apex stays at $0 recurring spend.

# ──────────────────────────────────────────────────────────────────────────
# AI inference · Groq (free fast Llama 3.3 / Mixtral / Whisper)
# ──────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# News aggregation · multi-source F1 coverage
# ──────────────────────────────────────────────────────────────────────────
NEWSAPI_KEY=
GUARDIAN_API_KEY=
NEWSDATA_API_KEY=
GNEWS_API_KEY=
CURRENTS_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Video · YouTube Data API v3 (10k units/day free)
# ──────────────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Imagery · Unsplash (free 50 req/h) + Giphy + HF inference fallback
# ──────────────────────────────────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=
GIPHY_API_KEY=
HUGGINGFACE_TOKEN=

# ──────────────────────────────────────────────────────────────────────────
# Newsletter · Resend (free: 3000 emails/mo, 100 contacts).
# Without BOTH set, /api/newsletter accepts the email but only logs it.
# Get a key at https://resend.com/api-keys.
# Create an audience at https://resend.com/audiences and copy its UUID.
# ──────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# ──────────────────────────────────────────────────────────────────────────
# Cron secret · used by /api/cron/* routes to reject non-Vercel callers.
# Generate with: openssl rand -base64 32
# Vercel cron auto-injects the x-vercel-cron header so this is a belt-and-
# braces gate for off-platform pokes.
# ──────────────────────────────────────────────────────────────────────────
CRON_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# Database · Supabase Postgres (free tier, 500MB)
# Format: postgres://USER:PASSWORD@HOST:PORT/DB?pgbouncer=true&sslmode=require
# Set on Vercel only after the Supabase project is provisioned.
# ──────────────────────────────────────────────────────────────────────────
DATABASE_URL=

# ──────────────────────────────────────────────────────────────────────────
# Public site URL · used for absolute OG / canonical / sitemap links.
# Set per env: production = https://apex-f1.vercel.app (or your domain),
# preview = automatic Vercel preview URL.
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=

# ──────────────────────────────────────────────────────────────────────────
# Optional · Ko-fi / Buy Me a Coffee handles for /support page.
# Until both are set the tip-jar buttons land on the provider homepages.
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TIP_JAR_KOFI=
NEXT_PUBLIC_TIP_JAR_BMC=
