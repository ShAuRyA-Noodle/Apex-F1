{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@apex/types": ["../../packages/types/src"],
      "@apex/ui": ["../../packages/ui/src"],
      "@apex/ui/tokens": ["../../packages/ui/src/tokens.ts"],
      "@apex/api-client": ["../../packages/api-client/src"],
      "@apex/api-client/jolpica": ["../../packages/api-client/src/jolpica"],
      "@apex/api-client/rss": ["../../packages/api-client/src/rss"],
      "@apex/api-client/reddit": ["../../packages/api-client/src/reddit"],
      "@apex/api-client/youtube": ["../../packages/api-client/src/youtube"],
      "@apex/api-client/openf1": ["../../packages/api-client/src/openf1"],
      "@apex/api-client/wikidata": ["../../packages/api-client/src/wikidata"]
    },
    "noEmit": true,
    "allowJs": true,
    "jsx": "preserve"
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
